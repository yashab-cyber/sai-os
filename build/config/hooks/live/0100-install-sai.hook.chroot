#!/bin/bash
# SAI-OS Live Build Hook — Install SAI components into the chroot
# This runs inside the chroot during ISO build
#
# NOTE: Ollama / AI backends are NOT installed here.
# The user chooses their backend on first boot or via sai-setup-backend.

set -e

echo "========================================="
echo "  SAI-OS Build Hook: Installing SAI Core"
echo "========================================="

# ── Create SAI user with sudo ──
echo "[1/3] Configuring SAI user..."
if ! id -u sai &>/dev/null; then
    useradd -m -s /bin/bash -G sudo,audio,video,plugdev,netdev sai
    echo "sai:sai" | chpasswd
    echo "sai ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/sai
fi

# ── Install SAI-OS Python package ──
echo "[2/3] Installing SAI-OS core..."
cd /opt
if [ -d "sai-os" ]; then
    cd sai-os
    pip3 install --break-system-packages -e "." || pip3 install -e "."
else
    echo "WARNING: sai-os source not found at /opt/sai-os"
fi

# ── Configure auto-login and session ──
echo "[3/3] Configuring desktop session..."

# Create Wayfire session desktop entry
cat > /usr/share/wayland-sessions/sai-desktop.desktop << 'EOF'
[Desktop Entry]
Name=SAI-OS Desktop
Comment=AI-Powered Desktop Environment
Exec=/usr/local/bin/sai-session
Type=Application
DesktopNames=SAI
EOF

# Create session launcher script
cat > /usr/local/bin/sai-session << 'SCRIPT'
#!/bin/bash
# SAI-OS Session Launcher

# Set environment
export XDG_CURRENT_DESKTOP=SAI
export SAI_SESSION=1
export GTK_THEME=sai-dark

# Start SAI daemon in background
sai-daemon &

# Start Ollama only if installed AND configured as the backend
if command -v ollama &>/dev/null; then
    SAI_BACKEND=$(grep -oP 'backend\s*=\s*"\K[^"]+' ~/.config/sai/config.toml 2>/dev/null || echo "")
    if [ "$SAI_BACKEND" = "ollama" ]; then
        ollama serve &
    fi
fi

# Launch Wayfire with SAI config
exec wayfire
SCRIPT
chmod +x /usr/local/bin/sai-session

# Enable auto-login via getty
mkdir -p /etc/systemd/system/getty@tty1.service.d
cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf << 'EOF'
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin sai --noclear %I $TERM
EOF

# Auto-start desktop session on login
cat >> /etc/skel/.bash_profile << 'EOF'

# Auto-start SAI Desktop
if [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
    exec sai-session
fi
EOF

echo "========================================="
echo "  SAI-OS Build Hook: Complete!"
echo "========================================="
