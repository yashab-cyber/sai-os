#!/bin/bash
# SAI-OS ISO Build Configuration
# Wraps `lb config` with SAI-OS defaults

set -e

lb config noauto \
    --architectures amd64 \
    --distribution bookworm \
    --archive-areas "main contrib non-free non-free-firmware" \
    --binary-images iso-hybrid \
    --bootappend-live "boot=live components username=sai hostname=sai-os" \
    --debian-installer none \
    --memtest none \
    --iso-application "SAI-OS" \
    --iso-publisher "SAI-OS Project" \
    --iso-volume "SAI-OS Live" \
    --debootstrap-options "--include=apt-transport-https,ca-certificates" \
    "${@}"

echo "✅ SAI-OS build configured."
